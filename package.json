{
  "name": "planty-wiki",
  "version": "0.1.0",
  "description": "A lightweight note-taking app running entirely in the browser",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "oshikiri",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "lint": "npm run lint:biome && npm run lint:architecture",
    "lint:biome": "biome lint",
    "lint:architecture": "depcruise --config scripts/dependency-cruiser.mjs src",
    "tsdoc-extract": "node scripts/tsdoc-extract.mjs",
    "format": "biome format --write",
    "format:check": "biome check . --formatter-enabled=true --linter-enabled=false --assist-enabled=false",
    "knip": "knip"
  },
  "dependencies": {
    "@lexical/code": "0.41.0",
    "@lexical/link": "0.42.0",
    "@lexical/list": "0.41.0",
    "@lexical/markdown": "0.41.0",
    "@lexical/react": "0.41.0",
    "@lexical/rich-text": "0.41.0",
    "@lexical/text": "0.41.0",
    "@lexical/utils": "0.41.0",
    "lexical": "0.41.0",
    "preact": "10.28.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@preact/preset-vite": "2.10.3",
    "@types/node": "25.3.5",
    "dependency-cruiser": "17.3.8",
    "jsdom": "28.1.0",
    "knip": "5.85.0",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vitest": "4.0.18"
  }
}
